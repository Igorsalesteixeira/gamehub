{
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit|Glob|Grep|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '[.tool_name, .tool_input] | @tsv' >> ~/.claude/projects/C--Users-igor--Downloads-Site-de-jogos/memory/session_tools.log 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Read",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode sandbox --tool $CLYDE_TOOL_NAME --input '$CLYDE_TOOL_INPUT' 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
